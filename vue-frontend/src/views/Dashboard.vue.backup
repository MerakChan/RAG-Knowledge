<template>
  <div class="dashboard-page">
    <!-- 1. 顶部导航区 -->
    <header class="top-navigation">
      <div class="nav-left">
        <div class="brand-section">
          <div class="brand-icon">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L2 7L12 12L22 7L12 2Z" fill="#3B82F6"/>
              <path d="M2 17L12 22L22 17" stroke="#3B82F6" stroke-width="2" stroke-linecap="round"/>
              <path d="M2 12L12 17L22 12" stroke="#3B82F6" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="brand-content">
            <h1 class="brand-name">知识空间站</h1>
            <div class="welcome-text">
              <span>欢迎回来，{{ authUser.nickname || authUser.username }}！</span>
              <span class="welcome-sub">今天也要高效学习，持续进步～</span>
            </div>
          </div>
        </div>
      </div>
      
      <div class="nav-right">
        <div class="quick-actions">
          <button class="btn btn-primary btn-compact" @click="openNoteModal">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M19 3H5C3.89543 3 3 3.89543 3 5V19C3 20.1046 3.89543 21 5 21H19C20.1046 21 21 20.1046 21 19V5C21 3.89543 20.1046 3 19 3Z" stroke="currentColor" stroke-width="2"/>
              <path d="M12 8V16M8 12H16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            新建笔记
          </button>
          <button class="btn btn-success btn-compact" @click="openKnowledgeModal()">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 5V19M5 12H19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            新建知识空间
          </button>
          <button class="btn btn-secondary btn-compact" @click="triggerFileImport">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M4 17V19C4 20.1046 4.89543 21 6 21H18C19.1046 21 20 20.1046 20 19V17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M12 3V15M12 15L8 11M12 15L16 11" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            导入文件
          </button>
        </div>
        
        <div class="user-profile-dropdown" :class="{ open: settingsOpen }">
          <div class="user-profile-mini" @click="toggleSettings">
            <div class="user-avatar">{{ (authUser.nickname || authUser.username || '学')[0] }}</div>
            <div class="user-info">
              <strong>{{ authUser.nickname || authUser.username }}</strong>
              <span>个人账号</span>
            </div>
            <svg class="dropdown-arrow" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="dropdown-menu" v-if="settingsOpen">
            <div class="dropdown-item" @click="openSettingsModal">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 15.5C13.933 15.5 15.5 13.933 15.5 12C15.5 10.067 13.933 8.5 12 8.5C10.067 8.5 8.5 10.067 8.5 12C8.5 13.933 10.067 15.5 12 15.5Z" fill="currentColor"/>
                <path d="M19.4 15C19.2 14.55 19 14.1 18.8 13.65C18.6833 13.3833 18.7 13.05 18.8 12.8L19.9 10.9C20.1 10.55 20.05 10.1 19.85 9.75L18.85 8C18.65 7.65 18.3 7.5 17.95 7.5L15.8 7.95C15.5 8 15.2 7.9 15 7.65L13.7 6.1C13.4 5.7 12.85 5.5 12.3 5.65L10.5 6.15C10.1 6.25 9.7 6.15 9.4 5.9L7.8 4.7C7.45 4.45 6.95 4.5 6.6 4.8L5.25 6.4C4.95 6.75 4.95 7.3 5.2 7.7L6.4 9.2C6.6 9.5 6.55 9.85 6.4 10.2L5.3 12C5.1 12.4 5.15 12.85 5.4 13.2L6.45 15C6.7 15.35 7.05 15.5 7.45 15.5L9.65 15.1C9.95 15.05 10.3 15.15 10.5 15.45L11.85 17.05C12.1 17.4 12.65 17.6 13.15 17.5L14.95 17C15.3 16.9 15.65 17 15.9 17.3L17.45 18.7C17.8 19.05 18.35 19.05 18.7 18.75L20.1 17.15C20.4 16.85 20.45 16.3 20.25 15.9L19.4 15Z" fill="currentColor"/>
              </svg>
              个人中心
            </div>
            <div class="dropdown-item" @click="openSettingsModal">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 15.5C13.933 15.5 15.5 13.933 15.5 12C15.5 10.067 13.933 8.5 12 8.5C10.067 8.5 8.5 10.067 8.5 12C8.5 13.933 10.067 15.5 12 15.5Z" fill="currentColor"/>
                <path d="M19.4 15C19.2 14.55 19 14.1 18.8 13.65C18.6833 13.3833 18.7 13.05 18.8 12.8L19.9 10.9C20.1 10.55 20.05 10.1 19.85 9.75L18.85 8C18.65 7.65 18.3 7.5 17.95 7.5L15.8 7.95C15.5 8 15.2 7.9 15 7.65L13.7 6.1C13.4 5.7 12.85 5.5 12.3 5.65L10.5 6.15C10.1 6.25 9.7 6.15 9.4 5.9L7.8 4.7C7.45 4.45 6.95 4.5 6.6 4.8L5.25 6.4C4.95 6.75 4.95 7.3 5.2 7.7L6.4 9.2C6.6 9.5 6.55 9.85 6.4 10.2L5.3 12C5.1 12.4 5.15 12.85 5.4 13.2L6.45 15C6.7 15.35 7.05 15.5 7.45 15.5L9.65 15.1C9.95 15.05 10.3 15.15 10.5 15.45L11.85 17.05C12.1 17.4 12.65 17.6 13.15 17.5L14.95 17C15.3 16.9 15.65 17 15.9 17.3L17.45 18.7C17.8 19.05 18.35 19.05 18.7 18.75L20.1 17.15C20.4 16.85 20.45 16.3 20.25 15.9L19.4 15Z" fill="currentColor"/>
              </svg>
              设置
            </div>
            <div class="dropdown-divider"></div>
            <div class="dropdown-item danger" @click="handleLogout">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M17 7L15.59 8.41L18.17 11H8V13H18.17L15.59 15.58L17 17L22 12L17 7Z" fill="currentColor"/>
                <path d="M6 3H12V5H6V19H12V21H6C4.9 21 4 20.1 4 19V5C4 3.9 4.9 3 6 3Z" fill="currentColor"/>
              </svg>
              退出
            </div>
          </div>
        </div>
      </div>
    </header>
    
    <main class="main-content">
      <!-- 2. 核心数据看板 -->
      <section class="data-dashboard">
        <div class="dashboard-header">
          <h2 class="section-title">核心数据看板</h2>
          <p class="section-subtitle">快速感知你的知识资产规模和使用活跃度</p>
        </div>
        
        <div class="stats-grid">
          <!-- 知识空间 -->
          <div class="stat-card card-primary">
            <div class="stat-header">
              <div class="stat-icon-box">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 2L2 7L12 12L22 7L12 2Z" fill="currentColor"/>
                  <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="stat-value">
                <strong>{{ knowledgeBases.length }}</strong>
                <span>知识空间</span>
              </div>
            </div>
            <div class="stat-details">
              <div class="space-tags">
                <span v-for="(kb, idx) in knowledgeBases.slice(0, 3)" :key="idx" class="tag-item">{{ kb.category || '通用学习' }}</span>
                <span v-if="knowledgeBases.length > 3" class="tag-more">+{{ knowledgeBases.length - 3 }}</span>
                <span v-if="knowledgeBases.length === 0" class="tag-empty">暂无分类</span>
              </div>
            </div>
            <button class="stat-action btn-primary btn-small" @click="openKnowledgeModal()">
              新建空间
            </button>
          </div>
          
          <!-- 文档总数 -->
          <div class="stat-card card-success">
            <div class="stat-header">
              <div class="stat-icon-box">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M14 2H6C4.89543 2 4 2.89543 4 4V20C4 21.1046 4.89543 22 6 22H18C19.1046 22 20 21.1046 20 20V8L14 2Z" fill="currentColor"/>
                  <path d="M14 2V8H20" stroke="white" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="stat-value">
                <strong>{{ stats.overall?.doc_count || 0 }}</strong>
                <span>文档总数</span>
              </div>
            </div>
            <div class="stat-details">
              <div class="doc-distribution">
                <span class="dist-item">笔记<span class="dist-num">0</span></span>
                <span class="dist-item">论文<span class="dist-num">0</span></span>
                <span class="dist-item">资料<span class="dist-num">0</span></span>
              </div>
            </div>
            <button class="stat-action btn-success btn-small" @click="openNoteModal">
              新建笔记
            </button>
          </div>
          
          <!-- 对话轮次 -->
          <div class="stat-card card-purple">
            <div class="stat-header">
              <div class="stat-icon-box">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M20 2H4C2.89543 2 2 2.89543 2 4V22L6 18H20C21.1046 18 22 17.1046 22 16V4C22 2.89543 21.1046 2 20 2Z" fill="currentColor"/>
                </svg>
              </div>
              <div class="stat-value">
                <strong>{{ stats.overall?.qa_count || 0 }}</strong>
                <span>对话轮次</span>
              </div>
            </div>
            <div class="stat-details">
              <p class="scene-desc">向AI提问/协作整理知识</p>
            </div>
            <button class="stat-action btn-purple btn-small" @click="openChat">
              发起对话
            </button>
          </div>
          
          <!-- 连续学习 -->
          <div class="stat-card card-orange">
            <div class="stat-header">
              <div class="stat-icon-box">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 2L4 5V11.09C4 16.14 7.41 20.85 12 22C16.59 20.85 20 16.14 20 11.09V5L12 2Z" fill="currentColor"/>
                </svg>
              </div>
              <div class="stat-value">
                <strong>{{ stats.workspace?.learning_streak_days || 0 }}</strong>
                <span>连续学习</span>
              </div>
            </div>
            <div class="stat-details">
              <div class="progress-container">
                <div class="progress-bar">
                  <div class="progress-fill" :style="{ width: `${Math.min((stats.workspace?.learning_streak_days || 0) / 7 * 100, 100)}%` }"></div>
                </div>
                <span class="progress-text">目标7天</span>
              </div>
            </div>
            <button class="stat-action btn-orange btn-small" @click="checkIn">
              今日学习打卡
            </button>
          </div>
        </div>
      </section>
      
      <!-- 3. 近期动态区 -->
      <section class="recent-activity">
        <div class="activity-grid">
          <!-- 最近在问什么 -->
          <div class="activity-card">
            <div class="card-header">
              <h3 class="card-title">最近在问什么</h3>
            </div>
            <div class="card-body">
              <div v-if="stats.recent_qa?.length" class="qa-list">
                <div v-for="(item, idx) in stats.recent_qa.slice(0, 4)" :key="idx" class="qa-item">
                  <div class="qa-content">
                    <strong class="qa-question">{{ item.question }}</strong>
                    <p class="qa-meta">
                      <span class="kb-name">{{ item.kb_name || '未命名知识空间' }}</span>
                      <span class="qa-time">今天 14:30</span>
                    </p>
                  </div>
                </div>
              </div>
              <div v-else class="empty-qa">
                <div class="empty-state">
                  <div class="empty-icon">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M20 2H4C2.89543 2 2 2.89543 2 4V22L6 18H20C21.1046 18 22 17.1046 22 16V4C22 2.89543 21.1046 2 20 2Z" fill="currentColor" opacity="0.2"/>
                    </svg>
                  </div>
                  <p class="empty-text">还没有问答记录～点击「提问」向AI咨询知识，或从笔记中自动生成问题</p>
                  <div class="sample-questions">
                    <div class="sample-item" @click="openChat">如何做毕业设计的文献综述？</div>
                  </div>
                  <button class="btn btn-primary" @click="openChat">提问</button>
                </div>
              </div>
            </div>
          </div>
          
          <!-- 最近在写什么 -->
          <div class="activity-card">
            <div class="card-header">
              <h3 class="card-title">最近在写什么</h3>
            </div>
            <div class="card-body">
              <div class="notes-list">
                <div v-for="(note, idx) in recentNotes" :key="idx" class="note-item">
                  <div class="note-content">
                    <strong class="note-title">{{ note.title }}</strong>
                    <p class="note-preview">{{ note.preview }}</p>
                    <div class="note-meta">
                      <span class="kb-badge">{{ note.kbName }}</span>
                      <span class="note-time">{{ note.updateTime }}</span>
                    </div>
                  </div>
                  <div class="note-actions">
                    <button class="icon-btn" title="继续编辑">
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 17.25V21H6.75L17.81 9.94L14.06 6.19L3 17.25Z" fill="currentColor"/>
                        <path d="M20.71 7.04C21.1 6.65 21.1 6.02 20.71 5.63L18.37 3.29C17.98 2.9 17.35 2.9 16.96 3.29L15.13 5.12L18.88 8.87L20.71 7.04Z" fill="currentColor"/>
                      </svg>
                    </button>
                    <button class="icon-btn" title="分享">
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M4 12V18C4 19.1046 4.89543 20 6 20H18C19.1046 20 20 19.1046 20 18V12" stroke="currentColor" stroke-width="2"/>
                        <path d="M16 6L12 2L8 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M12 2V14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                      </svg>
                    </button>
                    <button class="icon-btn" title="归档">
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 6H21V10H3V6Z" stroke="currentColor" stroke-width="2"/>
                        <path d="M5 10V18C5 19.1046 5.89543 20 7 20H17C18.1046 20 19 19.1046 19 18V10" stroke="currentColor" stroke-width="2"/>
                        <path d="M9 14H15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                      </svg>
                    </button>
                  </div>
                </div>
                <div v-if="recentNotes.length === 0" class="empty-notes">
                  <p>还没有笔记记录，开始你的创作吧！</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      
      <!-- 4. 学习节奏区 -->
      <section class="learning-rhythm">
        <div class="rhythm-header">
          <div>
            <h2 class="section-title">本周学习节奏（时长/次数）</h2>
            <p class="section-subtitle">每日学习时长/对话次数统计，助力习惯养成～</p>
          </div>
        </div>
        
        <div class="rhythm-content">
          <div class="timeline">
            <div v-for="(day, idx) in weekDays" :key="idx" class="timeline-item">
              <div class="day-label">{{ day.label }}</div>
              <div class="day-bar">
                <div class="bar-fill" :class="{ 'bar-achieved': day.achieved }" :style="{ height: `${day.height}%` }"></div>
              </div>
              <div class="day-stats">
                <span class="stat-duration">{{ day.duration }}</span>
                <span class="stat-count">{{ day.count }}次</span>
              </div>
            </div>
          </div>
          
          <div class="monthly-goal">
            <h4 class="goal-title">本月目标</h4>
            <p class="goal-desc">目标：每周学习≥5h，对话≥10次</p>
            <div class="goal-progress">
              <div class="progress-line">
                <div class="progress-segment">
                  <span class="segment-label">学习时长</span>
                  <div class="segment-bar">
                    <div class="segment-fill" style="width: 60%;"></div>
                  </div>
                  <span class="segment-value">3/5h</span>
                </div>
                <div class="progress-segment">
                  <span class="segment-label">对话次数</span>
                  <div class="segment-bar">
                    <div class="segment-fill" style="width: 20%;"></div>
                  </div>
                  <span class="segment-value">2/10次</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      
      <!-- 5. 知识空间管理区 -->
      <section class="knowledge-spaces">
        <div class="spaces-header">
          <div>
            <h2 class="section-title">知识空间管理</h2>
            <p class="section-subtitle">按学习主题/项目/学科分类，方便知识聚合</p>
          </div>
          <button class="btn btn-success" @click="openKnowledgeModal()">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 5V19M5 12H19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            新建空间
          </button>
        </div>
        
        <div class="spaces-grid">
          <div v-for="kb in knowledgeBases" :key="kb.id" class="space-card" @click="enterKnowledgeBase(kb)">
            <div class="space-header">
              <div class="space-title">
                <h3>{{ kb.name }}</h3>
                <span class="category-tag">{{ kb.category || '通用学习' }}</span>
              </div>
              <div class="space-actions" @click.stop>
                <button class="icon-btn" @click="openKnowledgeModal(kb)" title="编辑">
                  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 17.25V21H6.75L17.81 9.94L14.06 6.19L3 17.25Z" fill="currentColor"/>
                    <path d="M20.71 7.04C21.1 6.65 21.1 6.02 20.71 5.63L18.37 3.29C17.98 2.9 17.35 2.9 16.96 3.29L15.13 5.12L18.88 8.87L20.71 7.04Z" fill="currentColor"/>
                  </svg>
                </button>
                <button class="icon-btn delete" @click="confirmDeleteKnowledgeBase(kb)" title="删除">
                  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 19C6 20.1 6.9 21 8 21H16C17.1 21 18 20.1 18 19V7H6V19Z" fill="currentColor"/>
                    <path d="M19 4H15.5L14.5 3H9.5L8.5 4H5V6H19V4Z" fill="currentColor"/>
                  </svg>
                </button>
              </div>
            </div>
            <p class="space-desc">{{ kb.description || '暂无描述' }}</p>
            <div class="space-stats">
              <span class="stat-item">笔记 × {{ Math.floor(Math.random() * 10) }}</span>
              <span class="stat-item">文档 × {{ Math.floor(Math.random() * 5) }}</span>
            </div>
            <div class="space-footer">
              <span class="update-time">最近更新：今天</span>
              <button class="btn btn-primary btn-small" @click.stop="enterKnowledgeBase(kb)">进入空间</button>
            </div>
          </div>
          
          <div v-if="knowledgeBases.length === 0" class="empty-spaces">
            <div class="empty-state">
              <div class="empty-icon">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 2L2 7L12 12L22 7L12 2Z" fill="currentColor" opacity="0.2"/>
                </svg>
              </div>
              <h3>还没有知识空间</h3>
              <p>创建你的第一个知识空间，开始高效学习！</p>
              <button class="btn btn-success" @click="openKnowledgeModal()">创建第一个空间</button>
            </div>
          </div>
        </div>
      </section>
      
      <!-- 6. 底部辅助区 -->
      <section class="bottom-helper">
        <div class="helper-grid">
          <!-- 知识速查 -->
          <div class="helper-card">
            <div class="helper-header">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M21 21L16.65 16.65M19 11C19 15.4183 15.4183 19 11 19C6.58172 19 3 15.4183 3 11C3 6.58172 6.58172 3 11 3C15.4183 3 19 6.58172 19 11Z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
              <h3>知识速查</h3>
            </div>
            <div class="helper-links">
              <a href="#" class="helper-link">标签管理</a>
              <a href="#" class="helper-link">搜索全局知识</a>
              <a href="#" class="helper-link">知识图谱</a>
            </div>
          </div>
          
          <!-- 学习计划 -->
          <div class="helper-card">
            <div class="helper-header">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 7V3M16 7V3M3 11H21M5 21H19C20.1046 21 21 20.1046 21 19V5C21 3.89543 20.1046 3 19 3H5C3.89543 3 3 3.89543 3 5V19C3 20.1046 3.89543 21 5 21Z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
              <h3>学习计划</h3>
            </div>
            <div class="plan-list">
              <div class="plan-item" v-for="(plan, idx) in todayPlans" :key="idx">
                <input type="checkbox" v-model="plan.completed" class="plan-checkbox">
                <span :class="{ 'plan-completed': plan.completed }">{{ plan.text }}</span>
              </div>
            </div>
          </div>
          
          <!-- 最近归档 -->
          <div class="helper-card">
            <div class="helper-header">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 6H21V10H3V6Z" stroke="currentColor" stroke-width="2"/>
                <path d="M5 10V18C5 19.1046 5.89543 20 7 20H17C18.1046 20 19 19.1046 19 18V10" stroke="currentColor" stroke-width="2"/>
              </svg>
              <h3>最近归档</h3>
            </div>
            <div class="archive-list">
              <div v-for="(item, idx) in archivedItems" :key="idx" class="archive-item">
                <span class="archive-name">{{ item.name }}</span>
                <span class="archive-time">{{ item.time }}</span>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
    
    <!-- Modals -->
    <div v-if="knowledgeModal.visible" class="overlay-shell">
      <div class="overlay-card modal-card large-modal">
        <div class="panel-header">
          <div>
            <span class="section-label">{{ knowledgeModal.mode === 'create' ? '新建主题' : '编辑主题' }}</span>
            <h2>{{ knowledgeModal.mode === 'create' ? '创建知识空间' : '编辑知识空间' }}</h2>
          </div>
          <button class="modal-close" type="button" @click="closeKnowledgeModal">关闭</button>
        </div>
        <form class="modal-form" @submit.prevent="submitKnowledgeBase">
          <div class="modal-grid">
            <div>
              <label class="field-label">名称</label>
              <input v-model="knowledgeModal.form.name" class="field-input" type="text" placeholder="例如：毕业设计" />
            </div>
            <div>
              <label class="field-label">分类</label>
              <input v-model="knowledgeModal.form.category" class="field-input" type="text" placeholder="例如：项目研究" />
            </div>
          </div>
          <div>
            <label class="field-label">描述</label>
            <textarea v-model="knowledgeModal.form.description" class="field-textarea" placeholder="描述这个知识空间的内容边界"></textarea>
          </div>
          <div class="modal-actions">
            <button class="btn btn-secondary" type="button" @click="closeKnowledgeModal">取消</button>
            <button class="btn btn-success" type="submit" :disabled="loading">
              {{ loading ? '保存中...' : '保存' }}
            </button>
          </div>
        </form>
      </div>
    </div>
    
    <div v-if="settingsModal.visible" class="overlay-shell">
      <div class="overlay-card modal-card">
        <div class="panel-header">
          <div>
            <span class="section-label">系统设置</span>
            <h2>系统和用户相关设置</h2>
          </div>
          <button class="modal-close" type="button" @click="closeSettingsModal">关闭</button>
        </div>
        <form class="modal-form">
          <div class="setting-item">
            <label class="field-label">账号信息修改</label>
            <div class="form-group">
              <input v-model="settingsForm.username" class="field-input" type="text" placeholder="用户名" />
            </div>
            <div class="form-group">
              <input v-model="settingsForm.nickname" class="field-input" type="text" placeholder="昵称" />
            </div>
            <div class="form-group">
              <input v-model="settingsForm.email" class="field-input" type="email" placeholder="邮箱" />
            </div>
          </div>
          <div class="modal-actions">
            <button class="btn btn-secondary" type="button" @click="closeSettingsModal">取消</button>
            <button class="btn btn-primary" type="button" @click="saveSettings">保存修改</button>
          </div>
        </form>
      </div>
    </div>
    
    <input type="file" ref="fileInputRef" class="visually-hidden" @change="handleFileSelect">
  </div>
</template>

<script setup>
import axios from 'axios'
import { reactive, ref, onMounted, computed } from 'vue'
import { useRouter } from 'vue-router'
import { getAuthUser, clearAuthSession } from '../utils/auth'

const router = useRouter()
const authUser = getAuthUser()

const knowledgeBases = ref([])
const loading = ref(false)
const settingsOpen = ref(false)
const fileInputRef = ref(null)

const stats = reactive({
  overall: { doc_count: 0, qa_count: 0 },
  workspace: { learning_streak_days: 0 },
  recent_qa: [],
  today: { qa_count: 0 },
  daily_activity: []
})

const knowledgeModal = reactive({
  visible: false,
  mode: 'create',
  form: {
    id: '',
    name: '',
    description: '',
    category: '通用学习'
  }
})

const settingsModal = reactive({
  visible: false
})

const settingsForm = reactive({
  username: authUser?.username || '',
  nickname: authUser?.nickname || '',
  email: ''
})

// 模拟数据
const recentNotes = ref([
  {
    title: 'React Hooks 深度解析',
    preview: 'React Hooks 是 React 16.8 引入的新特性，它可以让你在不编写 class 的情况下使用 state...',
    kbName: '前端学习',
    updateTime: '今天 14:25'
  },
  {
    title: '毕业设计开题报告',
    preview: '本项目旨在研究人工智能在知识管理中的应用，通过构建知识库和问答系统，帮助用户...',
    kbName: '毕业设计',
    updateTime: '昨天 20:15'
  }
])

const weekDays = computed(() => {
  const days = ['周一', '周二', '周三', '周四', '周五', '周六', '周日']
  return days.map((day, idx) => ({
    label: day,
    duration: idx < 3 ? `${(Math.random() * 2 + 0.5).toFixed(1)}h` : '0h',
    count: idx < 3 ? Math.floor(Math.random() * 3 + 1) : 0,
    height: idx < 3 ? Math.floor(Math.random() * 60 + 40) : 0,
    achieved: idx < 3 && idx > 0
  }))
})

const todayPlans = ref([
  { text: '完成毕业设计文献综述笔记', completed: false },
  { text: '阅读《深度学习》第三章', completed: true },
  { text: '整理本周学习笔记', completed: false }
])

const archivedItems = ref([
  { name: '旧项目笔记', time: '3天前' },
  { name: '实习报告', time: '1周前' },
  { name: '课程作业', time: '2周前' }
])

const toggleSettings = () => {
  settingsOpen.value = !settingsOpen.value
}

const openSettingsModal = () => {
  settingsModal.visible = true
  settingsOpen.value = false
  settingsForm.username = authUser?.username || ''
  settingsForm.nickname = authUser?.nickname || ''
}

const closeSettingsModal = () => {
  settingsModal.visible = false
}

const saveSettings = async () => {
  try {
    await axios.put('/api/user/info', {
      username: settingsForm.username,
      nickname: settingsForm.nickname,
      email: settingsForm.email
    })
    authUser.nickname = settingsForm.nickname
    authUser.username = settingsForm.username
    closeSettingsModal()
  } catch (error) {
    console.error('保存设置失败', error)
  }
}

const handleLogout = () => {
  clearAuthSession()
  router.push('/login')
}

const loadKnowledgeBases = async () => {
  try {
    const { data } = await axios.get('/api/knowledge/list')
    knowledgeBases.value = data
  } catch (error) {
    console.error('加载知识空间失败', error)
  }
}

const loadDashboard = async () => {
  try {
    const { data } = await axios.get('/api/workspace/dashboard')
    Object.assign(stats, data)
  } catch (error) {
    console.error('加载工作台数据失败', error)
    stats.overall = { doc_count: 0, qa_count: 0 }
    stats.workspace = { learning_streak_days: 0 }
    stats.recent_qa = []
    stats.today = { qa_count: 0 }
    stats.daily_activity = []
  }
}

const openKnowledgeModal = (item = null) => {
  knowledgeModal.visible = true
  knowledgeModal.mode = item ? 'edit' : 'create'
  knowledgeModal.form.id = item?.id || ''
  knowledgeModal.form.name = item?.name || ''
  knowledgeModal.form.description = item?.description || ''
  knowledgeModal.form.category = item?.category || '通用学习'
}

const closeKnowledgeModal = () => {
  knowledgeModal.visible = false
}

const submitKnowledgeBase = async () => {
  if (!knowledgeModal.form.name.trim()) {
    return
  }

  loading.value = true
  try {
    if (knowledgeModal.mode === 'create') {
      await axios.post('/api/knowledge/create', knowledgeModal.form)
    } else {
      await axios.put('/api/knowledge/update', knowledgeModal.form)
    }
    await loadKnowledgeBases()
    closeKnowledgeModal()
  } catch (error) {
    console.error('保存知识空间失败', error)
  } finally {
    loading.value = false
  }
}

const confirmDeleteKnowledgeBase = async (kb) => {
  if (confirm('确定要删除这个知识空间吗？')) {
    try {
      await axios.delete('/api/knowledge/delete', { data: { id: kb.id } })
      await loadKnowledgeBases()
    } catch (error) {
      console.error('删除知识空间失败', error)
    }
  }
}

const enterKnowledgeBase = (kb) => {
  router.push({
    path: '/main',
    query: { knowledgeId: kb.id }
  })
}

const openNoteModal = () => {
  router.push('/main')
}

const openChat = () => {
  router.push('/main')
}

const checkIn = () => {
  alert('打卡成功！')
}

const triggerFileImport = () => {
  fileInputRef.value?.click()
}

const handleFileSelect = (e) => {
  const file = e.target.files[0]
  if (file) {
    alert(`已选择文件：${file.name}`)
  }
}

onMounted(() => {
  loadKnowledgeBases()
  loadDashboard()
})
</script>

