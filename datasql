create table app_user
(
    id            bigint auto_increment comment '用户ID'
        primary key,
    username      varchar(64)                           not null comment '登录用户名',
    password_hash varchar(255)                          not null comment '密码哈希',
    nickname      varchar(100)                          null comment '昵称',
    status        varchar(20) default 'active'          not null comment 'active/inactive',
    create_time   datetime    default CURRENT_TIMESTAMP null comment '创建时间',
    update_time   datetime    default CURRENT_TIMESTAMP null on update CURRENT_TIMESTAMP comment '更新时间',
    constraint username
        unique (username)
)
    comment '系统用户表';

create index idx_app_user_status
    on app_user (status);

create table knowledge_base
(
    id              bigint auto_increment comment '知识库ID'
        primary key,
    user_id         bigint                                    null comment '所属用户ID',
    name            varchar(100)                              not null comment '知识库名称',
    description     mediumtext                                null comment '知识库描述',
    embedding_model varchar(100) default 'bge-large'          null comment '向量模型',
    vector_store    varchar(50)  default 'faiss'              null comment '向量数据库类型',
    tags            mediumtext                                null comment '知识库标签，JSON 数组',
    cover_url       varchar(500)                              null comment '知识库封面 URL',
    category        varchar(100)                              null comment '知识库分类',
    retrieval_mode  varchar(50)  default 'hybrid'             not null comment '检索模式',
    chunk_strategy  varchar(100) default 'paragraph-balanced' not null comment 'Chunk 策略',
    persona         longtext                                  null comment '角色设定/背景设定',
    thinking_style  varchar(50)  default 'teaching'           not null comment '思考方式（teaching/interview/summary/reasoning）',
    task_policy     json                                      null comment '任务策略（JSON数组）',
    model_strategy  varchar(255)                              null comment '模型策略',
    background_url  varchar(500)                              null comment '背景图片URL',
    create_time     datetime     default CURRENT_TIMESTAMP    null comment '创建时间',
    update_time     datetime     default CURRENT_TIMESTAMP    null on update CURRENT_TIMESTAMP comment '更新时间'
)
    comment '知识库表';

create table chat_session
(
    id           bigint auto_increment comment '会话ID'
        primary key,
    knowledge_id bigint                             not null comment '知识库ID',
    session_name varchar(255)                       null comment '会话名称',
    create_time  datetime default CURRENT_TIMESTAMP null,
    update_time  datetime default CURRENT_TIMESTAMP null on update CURRENT_TIMESTAMP,
    constraint fk_session_kb
        foreign key (knowledge_id) references knowledge_base (id)
)
    comment '聊天会话表';

create table chat_message
(
    id           bigint auto_increment comment '消息ID'
        primary key,
    session_id   bigint                                not null comment '会话ID',
    role         varchar(20)                           not null comment 'user/assistant',
    content      longtext                              null comment '消息内容',
    message_type varchar(20) default 'text'            null comment 'text/sql/table',
    create_time  datetime    default CURRENT_TIMESTAMP null,
    constraint fk_msg_session
        foreign key (session_id) references chat_session (id)
)
    comment '聊天消息记录';

create index idx_knowledge_base_category
    on knowledge_base (category);

create index idx_knowledge_base_update_time
    on knowledge_base (update_time);

create table knowledge_data
(
    id           bigint auto_increment comment '知识数据ID'
        primary key,
    knowledge_id bigint                             not null comment '所属知识库ID',
    title        varchar(255)                       null comment '标题',
    content      longtext                           not null comment '知识内容',
    source_type  varchar(50)                        null comment 'manual/document/database',
    source_id    bigint                             null comment '来源ID',
    create_time  datetime default CURRENT_TIMESTAMP null comment '创建时间',
    constraint fk_data_kb
        foreign key (knowledge_id) references knowledge_base (id)
)
    comment '知识数据表';

create table knowledge_datasource
(
    id              bigint auto_increment comment '数据源ID'
        primary key,
    knowledge_id    bigint                                not null comment '所属知识库',
    datasource_name varchar(255)                          null comment '数据源名称',
    db_type         varchar(50)                           null comment 'mysql/postgres',
    host            varchar(255)                          null,
    port            int                                   null,
    database_name   varchar(255)                          null,
    username        varchar(255)                          null,
    password        varchar(255)                          null,
    status          varchar(20) default 'active'          null,
    create_time     datetime    default CURRENT_TIMESTAMP null,
    constraint fk_ds_kb
        foreign key (knowledge_id) references knowledge_base (id)
)
    comment '知识库数据源表';

create table knowledge_document
(
    id           bigint auto_increment comment '文档ID'
        primary key,
    knowledge_id bigint                                not null comment '所属知识库ID',
    file_name    varchar(255)                          null comment '文件名',
    file_path    varchar(500)                          null comment '文件存储路径',
    file_type    varchar(50)                           null comment '文件类型(pdf/docx/txt)',
    file_size    bigint                                null comment '文件大小',
    parse_status varchar(50) default 'waiting'         null comment '解析状态',
    create_time  datetime    default CURRENT_TIMESTAMP null comment '上传时间',
    constraint fk_doc_kb
        foreign key (knowledge_id) references knowledge_base (id)
)
    comment '知识文档表';

create table knowledge_chunk
(
    id            bigint auto_increment comment 'chunk ID'
        primary key,
    knowledge_id  bigint                                not null comment '知识库ID',
    data_id       bigint                                null comment '知识数据ID',
    document_id   bigint                                null comment '文档ID',
    chunk_text    longtext                              not null comment '文本块内容',
    chunk_index   int                                   null comment '文本块顺序',
    vector_status varchar(50) default 'waiting'         null comment '向量化状态',
    create_time   datetime    default CURRENT_TIMESTAMP null,
    constraint fk_chunk_data
        foreign key (data_id) references knowledge_data (id),
    constraint fk_chunk_doc
        foreign key (document_id) references knowledge_document (id),
    constraint fk_chunk_kb
        foreign key (knowledge_id) references knowledge_base (id)
)
    comment '文本chunk表';

create table knowledge_item
(
    id                bigint auto_increment
        primary key,
    knowledge_id      bigint                                not null comment '所属知识库',
    title             varchar(255)                          null comment '知识标题',
    source_type       varchar(50)                           null comment 'manual/file/mysql',
    content           longtext                              null comment '文本内容',
    file_name         varchar(255)                          null,
    file_path         varchar(500)                          null,
    datasource_config json                                  null,
    chunk_count       int         default 0                 null,
    status            varchar(20) default 'processing'      null,
    create_time       datetime    default CURRENT_TIMESTAMP null,
    constraint fk_item_kb
        foreign key (knowledge_id) references knowledge_base (id)
)
    comment '综合知识条目表';

create table knowledge_table_schema
(
    id             bigint auto_increment comment '主键ID'
        primary key,
    datasource_id  bigint                             not null comment '数据源ID',
    table_name     varchar(255)                       not null comment '表名',
    column_name    varchar(255)                       not null comment '字段名',
    column_type    varchar(100)                       null comment '字段类型',
    column_comment varchar(255)                       null comment '字段备注',
    is_primary_key tinyint  default 0                 null comment '是否主键',
    create_time    datetime default CURRENT_TIMESTAMP null,
    constraint fk_schema_ds
        foreign key (datasource_id) references knowledge_datasource (id)
)
    comment '数据库表结构信息';

create table learning_database_note
(
    id              bigint auto_increment comment '数据库笔记ID'
        primary key,
    user_id         bigint                                null comment '所属用户ID',
    knowledge_id    bigint                                null comment '关联知识库ID',
    title           varchar(255)                          not null comment '笔记标题',
    note_type       varchar(50) default 'sql'             not null comment 'sql/code/bugfix/summary',
    code_language   varchar(50) default 'sql'             not null comment '代码语言',
    sql_text        longtext                              not null comment 'SQL 语句',
    issue_note      longtext                              null comment 'Bug说明或关键知识点',
    schema_snapshot longtext                              null comment '表结构快照',
    query_result    json                                  null comment '查询结果',
    summary         longtext                              null comment '总结说明',
    tags            mediumtext                            null comment '标签 JSON 数组',
    create_time     datetime    default CURRENT_TIMESTAMP null,
    update_time     datetime    default CURRENT_TIMESTAMP null on update CURRENT_TIMESTAMP
)
    comment '数据库学习笔记表';

create index idx_db_note_knowledge_id
    on learning_database_note (knowledge_id);

create index idx_db_note_update_time
    on learning_database_note (update_time);

create table learning_quick_note
(
    id                bigint auto_increment comment '快速笔记ID'
        primary key,
    knowledge_id      bigint                             not null comment '所属知识库ID',
    knowledge_item_id bigint                             null comment '关联知识条目ID',
    title             varchar(255)                       null comment '笔记标题',
    content           longtext                           not null comment '笔记内容',
    tags              mediumtext                         null comment '标签 JSON 数组',
    is_favorite       tinyint  default 0                 not null comment '是否收藏',
    is_pinned         tinyint  default 0                 not null comment '是否置顶',
    create_time       datetime default CURRENT_TIMESTAMP null,
    update_time       datetime default CURRENT_TIMESTAMP null on update CURRENT_TIMESTAMP
)
    comment '手动快速笔记表';

create index idx_quick_note_knowledge_id
    on learning_quick_note (knowledge_id);

create index idx_quick_note_update_time
    on learning_quick_note (update_time);

create table learning_web_bookmark
(
    id           bigint auto_increment comment '网页收藏ID'
        primary key,
    user_id      bigint                                null comment '所属用户ID',
    knowledge_id bigint                                null comment '关联知识库ID',
    title        varchar(255)                          not null comment '网页标题',
    url          varchar(1000)                         not null comment '网页地址',
    content      longtext                              null comment '解析后的正文',
    summary      longtext                              null comment 'AI 摘要',
    tags         mediumtext                            null comment '标签 JSON 数组',
    status       varchar(20) default 'ready'           not null comment 'ready/error',
    create_time  datetime    default CURRENT_TIMESTAMP null,
    update_time  datetime    default CURRENT_TIMESTAMP null on update CURRENT_TIMESTAMP
)
    comment '网页收藏表';

create index idx_bookmark_knowledge_id
    on learning_web_bookmark (knowledge_id);

create index idx_bookmark_update_time
    on learning_web_bookmark (update_time);

